# Server
DATABASE_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres?sslmode=require
OPENAI_API_KEY=sk-proj-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
PORT=5000
HOST=0.0.0.0

# Comma-separated browser origins allowed by the API.
# Expo Go/native fetches usually do not send an Origin header, but web/local
# testing and the static landing page can.
ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# Client
# Prefer a full URL for local, LAN, Render, and EAS testing.
EXPO_PUBLIC_API_URL=http://localhost:5000

# Legacy Replit-compatible fallback. Leave unset unless needed.
# EXPO_PUBLIC_DOMAIN=your-api.onrender.com
